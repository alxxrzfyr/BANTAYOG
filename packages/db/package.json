{
  "name": "@bantayog/db",
  "version": "0.1.0",
  "private": true,
  "description": "Typed Supabase clients and ER-aware query helpers for BANTAYOG (BE1 owns; FE1 imports for read-only)",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit --project tsconfig.json",
    "lint": "eslint . --config ../config/eslint.config.js --max-warnings 0",
    "type-check": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4"
  },
  "devDependencies": {
    "@bantayog/config": "workspace:*",
    "@types/node": "^22.10.5",
    "vitest": "^2.1.8",
    "typescript": "^5.7.2"
  }
}
