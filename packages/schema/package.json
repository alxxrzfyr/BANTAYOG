{
  "name": "@bantayog/schema",
  "version": "0.1.0",
  "private": true,
  "description": "Zod DTOs and RPC type contracts for BANTAYOG (BE1 owns; co-designed with FE1+FE2)",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit --project tsconfig.json",
    "lint": "eslint . --config ../config/eslint.config.js --max-warnings 0",
    "type-check": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@bantayog/config": "workspace:*",
    "vitest": "^2.1.8",
    "typescript": "^5.7.2"
  }
}
