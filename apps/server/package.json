{
  "name": "@bantayog/server",
  "version": "0.1.0",
  "private": true,
  "description": "BANTAYOG Hono 4 API server — services, domain, repositories, middleware (BE1+BE2 ownership)",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "build": "tsc --noEmit --project tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "boot": "tsx scripts/boot-local.ts",
    "lint": "eslint . --config ../../packages/config/eslint.config.js --max-warnings 0",
    "type-check": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@bantayog/db": "workspace:*",
    "@bantayog/schema": "workspace:*",
    "@google/genai": "^2.10.0",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.2",
    "@node-rs/argon2": "^2.0.2",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.3",
    "hono": "^4.6.14",
    "jose": "^6.2.3",
    "neverthrow": "^8.2.0",
    "p-retry": "^8.0.0",
    "pino": "^9.5.0",
    "viem": "^2.54.0",
    "xstate": "^5.32.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@bantayog/config": "workspace:*",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
