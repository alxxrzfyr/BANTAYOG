{
  "extends": "@bantayog/config/tsconfig/nextjs-web.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/components/*": ["./components/*"],
      "@/stores/*": ["./stores/*"],
      "@/providers/*": ["./providers/*"],
      "@/app/*": ["./app/*"],
      "@/lib/*": ["./lib/*"],
      "@bantayog/db": ["../../packages/db/src/index.ts"],
      "@bantayog/schema": ["../../packages/schema/src/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
